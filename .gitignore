# OS noise
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/

# Local notes (gitignored per diary convention)
Diary/

# Env files (workspace-level .gitignores also cover these)
.env
.env.local

# Build / dependency artifacts
node_modules/
dist/
.next/
.next.bak/

# Supabase CLI working state (link/db diff/db push scratch)
supabase/.temp/

# Vercel project link (root-level; web/.gitignore covers web/.vercel)
.vercel/

# Logs
*.log

# Ingest cache (cost ledger, enrichment lookup cache, etc.) — persisted
# between runs for idempotency but contains nothing portable across machines.
data/.cache/
.session-logs/
backups/
