{
  "version": 8,
  "name": "Overlander — Apple-inspired Dark",
  "metadata": {
    "mapbox:type": "default",
    "mapbox:origin": "overlander",
    "description": "Deep teal water, forest-green land with hillshading, cream highways. Inspired by Apple Maps dark mode."
  },
  "sources": {
    "composite": {
      "url": "mapbox://mapbox.mapbox-streets-v8,mapbox.mapbox-terrain-v2",
      "type": "vector"
    },
    "mapbox-dem": {
      "url": "mapbox://mapbox.mapbox-terrain-dem-v1",
      "type": "raster-dem",
      "tileSize": 512,
      "maxzoom": 14
    }
  },
  "sprite": "mapbox://sprites/mapbox/streets-v12",
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "terrain": { "source": "mapbox-dem", "exaggeration": 1.0 },
  "light": {
    "anchor": "viewport",
    "color": "#ffffff",
    "intensity": 0.35,
    "position": [1.15, 210, 30]
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#213E4F" }
    },

    {
      "id": "landuse-park",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["match", ["get", "class"], ["park", "wood", "grass", "scrub", "pitch", "cemetery"], true, false],
      "paint": {
        "fill-color": "#064A4C",
        "fill-opacity": 1
      }
    },
    {
      "id": "landuse-park-overlay",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse_overlay",
      "filter": ["==", ["get", "class"], "national_park"],
      "paint": {
        "fill-color": "#064A4C",
        "fill-opacity": 1
      }
    },
    {
      "id": "landuse-sand",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "sand"],
      "paint": { "fill-color": "#4C5B64" }
    },
    {
      "id": "landuse-airport",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "airport"],
      "paint": { "fill-color": "#213E4F" }
    },
    {
      "id": "landuse-parking",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "parking"],
      "paint": { "fill-color": "#213E4F" }
    },

    {
      "id": "hillshade",
      "type": "hillshade",
      "source": "mapbox-dem",
      "paint": {
        "hillshade-shadow-color": "#0A1E18",
        "hillshade-highlight-color": "#3A5A48",
        "hillshade-accent-color": "#1A3328",
        "hillshade-illumination-anchor": "viewport",
        "hillshade-illumination-direction": 335,
        "hillshade-exaggeration": 0.5
      }
    },

    {
      "id": "water",
      "type": "fill",
      "source": "composite",
      "source-layer": "water",
      "paint": { "fill-color": "#143C5A" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "composite",
      "source-layer": "waterway",
      "minzoom": 8,
      "paint": {
        "line-color": "#143C5A",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.4, 18, 4]
      }
    },

    {
      "id": "admin-state",
      "type": "line",
      "source": "composite",
      "source-layer": "admin",
      "filter": ["all", ["==", ["get", "admin_level"], 1], ["==", ["get", "maritime"], "false"]],
      "paint": {
        "line-color": "#3F5A4A",
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.4, 12, 1.5],
        "line-dasharray": [3, 2]
      }
    },
    {
      "id": "admin-country",
      "type": "line",
      "source": "composite",
      "source-layer": "admin",
      "filter": ["all", ["==", ["get", "admin_level"], 0], ["==", ["get", "maritime"], "false"]],
      "paint": {
        "line-color": "#5C7768",
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 0.6, 10, 2.5]
      }
    },

    {
      "id": "road-path",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["path", "track"], true, false],
      "minzoom": 14,
      "paint": {
        "line-color": "#7A8580",
        "line-width": ["interpolate", ["linear"], ["zoom"], 14, 0.5, 18, 1.5],
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "road-pedestrian",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["==", ["get", "class"], "pedestrian"],
      "minzoom": 14,
      "paint": {
        "line-color": "#B8BEC2",
        "line-width": ["interpolate", ["linear"], ["zoom"], 14, 1, 18, 4]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["service", "street", "street_limited"], true, false],
      "minzoom": 12,
      "paint": {
        "line-color": "#314A57",
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 12, 0.5, 14, 1.2, 16, 3, 18, 6]
      }
    },
    {
      "id": "road-secondary-tertiary",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["secondary", "tertiary"], true, false],
      "minzoom": 8,
      "paint": {
        "line-color": "#436373",
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 8, 0.4, 12, 1.5, 16, 5, 18, 9]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["==", ["get", "class"], "primary"],
      "minzoom": 6,
      "paint": {
        "line-color": "#436373",
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 6, 0.5, 10, 1.4, 14, 4, 18, 12]
      }
    },
    {
      "id": "road-trunk-motorway",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["motorway", "trunk"], true, false],
      "paint": {
        "line-color": "#67899B",
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 5, 0.6, 10, 2, 14, 6, 18, 16]
      }
    },

    {
      "id": "road-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 12,
      "filter": ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary", "tertiary"], true, false],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 9, 18, 13],
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#9CB8B0",
        "text-halo-color": "#0F2419",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "road-label-minor",
      "type": "symbol",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 14,
      "filter": ["match", ["get", "class"], ["service", "street", "street_limited", "pedestrian"], true, false],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 9, 18, 12],
        "text-letter-spacing": 0.04
      },
      "paint": {
        "text-color": "#7C9890",
        "text-halo-color": "#0F2419",
        "text-halo-width": 1
      }
    },

    {
      "id": "highway-shield",
      "type": "symbol",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 8,
      "filter": ["all", ["match", ["get", "class"], ["motorway", "trunk", "primary"], true, false], ["has", "shield"]],
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 350,
        "text-field": ["coalesce", ["get", "ref"], ""],
        "text-font": ["DIN Pro Bold", "Arial Unicode MS Bold"],
        "text-size": 11,
        "icon-image": ["concat", ["get", "shield"], "-2"],
        "icon-rotation-alignment": "viewport",
        "text-rotation-alignment": "viewport"
      },
      "paint": {
        "text-color": "#FFFFFF",
        "text-halo-color": "#000000",
        "text-halo-width": 0.5
      }
    },

    {
      "id": "settlement-minor-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "filter": ["match", ["get", "type"], ["village", "town", "suburb", "neighbourhood"], true, false],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 10, 14, 13],
        "text-letter-spacing": 0.06
      },
      "paint": {
        "text-color": "#B8D5C0",
        "text-halo-color": "#0F2419",
        "text-halo-width": 1.4
      }
    },
    {
      "id": "settlement-major-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "filter": ["match", ["get", "type"], ["city"], true, false],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Pro Bold", "Arial Unicode MS Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 12, 18]
      },
      "paint": {
        "text-color": "#EEF7EE",
        "text-halo-color": "#0F2419",
        "text-halo-width": 1.6
      }
    },
    {
      "id": "country-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "maxzoom": 8,
      "filter": ["==", ["get", "type"], "country"],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Pro Bold", "Arial Unicode MS Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 1, 10, 8, 22],
        "text-letter-spacing": 0.1,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#D5E5D8",
        "text-halo-color": "#0F2419",
        "text-halo-width": 1.6
      }
    },

    {
      "id": "natural-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "natural_label",
      "minzoom": 8,
      "filter": ["match", ["get", "class"], ["mountain", "peak", "bay", "sea", "ocean", "water", "cape", "headland"], true, false],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Pro Italic", "Arial Unicode MS Regular"],
        "text-size": 12,
        "text-letter-spacing": 0.04
      },
      "paint": {
        "text-color": "#7299B1",
        "text-halo-color": "#0A1E2E",
        "text-halo-width": 1.2
      }
    },

    {
      "id": "poi-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "poi_label",
      "minzoom": 13,
      "filter": ["match", ["get", "class"], ["park_like", "landmark", "historic"], true, false],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Regular"],
        "text-size": 11,
        "text-anchor": "top",
        "text-offset": [0, 0.6]
      },
      "paint": {
        "text-color": "#B4BFC5",
        "text-halo-color": "#0F2419",
        "text-halo-width": 1
      }
    }
  ]
}
