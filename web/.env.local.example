# Mapbox public token — https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.replace_me

# Mapillary v4 access token — https://www.mapillary.com/dashboard/developers
# Optional. When set, the discovery layer fills in street-level photos
# for browse-panel results that Wikidata didn't cover. Skipped silently
# when missing. Format: MLY|<app_id>|<app_secret>
MAPILLARY_TOKEN=
