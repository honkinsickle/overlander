# Mapbox public token — https://account.mapbox.com/access-tokens/
# Required. Powers the map style + geocoding. Without it the app falls
# back to a black map.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.replace_me

# ────── Supabase ──────
# Required for auth + user-trip persistence. Without these, the app falls
# back to .alaska-snapshot.json for the reference trip and auth surfaces
# no-op. Provision a project at https://supabase.com/dashboard, then
# Project Settings → API to grab the keys below. Apply the migration in
# supabase/migrations/ via the dashboard SQL editor before first run.
# Service-role key bypasses RLS — server-only, never expose to the client.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_me
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me

# ────── Discovery sources ──────
# The discovery layer fans out across multiple data sources to populate
# the browse panel. Each source below is optional and skipped silently
# when its key is missing; running with all four set produces the richest
# results. USFS, BLM, and Wikipedia are public — no key needed.
# Run `./bin/preflight` after editing to verify each source is reachable.

# Mapillary v4 access token — https://www.mapillary.com/dashboard/developers
# Fills in street-level photos for browse-panel results that Wikidata
# didn't cover. Format: MLY|<app_id>|<app_secret>
MAPILLARY_TOKEN=

# RIDB (Recreation.gov) API key — https://ridb.recreation.gov/
# Adds federal campgrounds + recreation facilities to browse results.
RIDB_API_KEY=

# Foursquare Places API key — https://foursquare.com/developers
# Adds food, fuel, lodging, and general POIs to browse results.
FSQ_API_KEY=

# Overpass API endpoint — defaults to https://overpass.kumi.systems/api/interpreter
# Override only if the default mirror is rate-limiting or unreachable
# from your network. Alternates: https://overpass-api.de/api/interpreter,
# https://overpass.openstreetmap.fr/api/interpreter
OVERPASS_URL=

# ────── Search (Typesense) ──────
# Phase 2 search slice. The query path (web route) uses a scoped
# search-only API key — never the admin key. Provision both keys in
# Typesense Cloud → API Keys (admin = full r/w for sync, search-only =
# read scope for `places` collection). Host/port/protocol are public
# (the same values as data/.env). The search key is NEXT_PUBLIC_
# because the query runs in the browser; scoping enforces safety.
NEXT_PUBLIC_TYPESENSE_HOST=<xxx>.a1.typesense.net
NEXT_PUBLIC_TYPESENSE_PORT=443
NEXT_PUBLIC_TYPESENSE_PROTOCOL=https
NEXT_PUBLIC_TYPESENSE_SEARCH_API_KEY=<search_only_api_key>
# One shared cluster, one collection PER ENVIRONMENT (places_prod / places_test) — never share. Must match data's TYPESENSE_COLLECTION for the same env.
NEXT_PUBLIC_TYPESENSE_COLLECTION=places_<env>
