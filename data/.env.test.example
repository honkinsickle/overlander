# Phase 2.5 Part B Option 1 — isolated test project.
#
# When present and populated, data/test-setup.ts overrides
# SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY with these values and sets
# ALLOW_DESTRUCTIVE_TEST_RESET=true, routing the entire vitest suite
# at the isolated test project. The reset_phase3a_test_state() RPC
# only succeeds against a project where public.test_marker has a row;
# scripts/seed-test-fixtures.ts inserts that row at seed time.
#
# Provision a second Supabase project (free tier is fine — test data
# is small), then run:
#   npm run -w data test:seed   (one-off; copies prod source_records here)
#   npm run -w data test         (runs the suite)
#
# If this file is absent or these values are empty, the suite skips
# every test with a clear warning. Production data is never touched.

SUPABASE_TEST_URL=https://<test-project-ref>.supabase.co
SUPABASE_TEST_SERVICE_ROLE_KEY=<test_service_role_jwt>
