# Supabase — share the same project as web/.env.local for Phase 1.
# Service role key is required: ingestion bypasses RLS.
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_jwt>
SUPABASE_ANON_KEY=<anon_jwt>

# Source API keys.
RIDB_API_KEY=
NPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# OSM Overpass — no key needed. Specify a rate-limit-friendly mirror.
# Var name matches the existing repo convention (bin/preflight uses OVERPASS_URL).
# Known working mirrors (kumi.systems is the default — bin/preflight validates it):
#   https://overpass.kumi.systems/api/interpreter      (default, recommended)
#   https://overpass.private.coffee/api/interpreter    (alt mirror)
#   https://overpass-api.de/api/interpreter            (primary; heavily loaded)
OVERPASS_URL=https://overpass.kumi.systems/api/interpreter

# Logging.
LOG_LEVEL=info
NODE_ENV=development
